# ─── 应用配置 ───────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-in-production

# ─── 数据库 ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_algo_interview
REDIS_URL=redis://localhost:6379/0

# ─── 向量数据库 ──────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=questions

# ─── LLM 配置（三选一）────────────────────────────────
# Ollama 本地（默认）
LLM_PROVIDER=ollama
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3.5:latest
LLM_MODEL_FAST=qwen3.5:latest

# DeepSeek 云端
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your-deepseek-api-key
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_MODEL_FAST=deepseek-chat

# QWen 云端
# LLM_PROVIDER=qwen
# LLM_API_KEY=your-qwen-api-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_MODEL_FAST=qwen-turbo

# ─── Embedding ────────────────────────────────────────
EMBEDDING_API_KEY=ollama
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text

# ─── Judge0 ───────────────────────────────────────────
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-judge0-api-key

# ─── LLM 调用参数 ─────────────────────────────────────
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SELECT=8
LLM_TIMEOUT_ANALYZE=30
LLM_TIMEOUT_FEEDBACK=30
LLM_MAX_RETRIES=2

# ─── 业务配置 ─────────────────────────────────────────
QUESTION_CACHE_TTL=604800
STREAM_CHUNK_TIMEOUT=5
DAILY_SWAP_LIMIT=2

JUDGE_PROVIDER=subprocess
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-key